# Django
DJANGO_SECRET_KEY=replace-with-a-real-secret-key
DJANGO_DEBUG=True

# Database (PostgreSQL)
DB_NAME=school_exam_db
DB_USER=postgres
DB_PASSWORD=your-password-here
DB_HOST=127.0.0.1
DB_PORT=5432

# Redis (Celery broker)
CELERY_BROKER_URL=redis://127.0.0.1:6379/0
CELERY_RESULT_BACKEND=redis://127.0.0.1:6379/1

# Email
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password

# Security (optional)
FIELD_ENCRYPTION_KEY=leave-empty-to-use-secret-key
DATA_INTEGRITY_KEY=leave-empty-to-use-secret-key
